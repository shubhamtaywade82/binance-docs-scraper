EXCHANGE=binance
START_URL=https://developers.binance.com/docs/derivatives/change-log
ALLOWED_PATH_PREFIX=/docs/derivatives
OUTPUT_DIR=docs
COMBINED_README=true
MAX_RETRIES=3
REQUEST_DELAY_MS=750
CONCURRENCY=4
MIN_MARKDOWN_LENGTH=300

# For Delta: EXCHANGE=delta START_URL=https://docs.delta.exchange

# For Ollama docs: EXCHANGE=ollama START_URL=https://docs.ollama.com/api/introduction
