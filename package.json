{
  "name": "binance-docs-scraper",
  "version": "1.0.0",
  "type": "module",
  "description": "Recursive Binance USDⓈ-M Futures docs scraper to Markdown",
  "main": "src/scrape.ts",
  "scripts": {
    "scrape": "tsx src/scrape.ts",
    "test": "tsx --test src/**/*.test.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "binance",
    "docs",
    "scraper",
    "playwright",
    "markdown"
  ],
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.1",
    "p-limit": "^6.1.0",
    "playwright": "^1.54.0",
    "slugify": "^1.6.6",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cheerio": "^0.22.35",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
